OPENAI_API_KEY=sk-...
TAVILY_API_KEY=tvly-...

# Tavily search — clamped to [1, 20] by TavilySearchService.
TAVILY_MAX_RESULTS=4

# Crawler limits.
CRAWLER_TARGET_TOTAL=16
CRAWLER_BOUNDARY_MAX_POSTS=24

# Crawler coverage / imbalance warning thresholds (percentages).
CRAWLER_COVERAGE_WARN_PERCENT=70
CRAWLER_COVERAGE_CRITICAL_PERCENT=45
CRAWLER_UNASSIGNED_WARN_PERCENT=40
CRAWLER_PLATFORM_IMBALANCE_WARN_GAP=70

# Crawler relevance scoring.
CRAWLER_RELEVANCE_MIN_SAMPLE=12
CRAWLER_RELEVANCE_MIN_SCORE=4
CRAWLER_RELEVANCE_MIN_RETAIN_COUNT=2
CRAWLER_RELEVANCE_MIN_RETAIN_RATIO=0.15
CRAWLER_RELEVANCE_MAX_HASHTAGS=2
CRAWLER_RELEVANCE_PLATFORM_CAP=8

# Optional: comma-separated list for cross-origin access.
# In same-origin deployments this can be left unset.
# CORS_ALLOWED_ORIGINS=http://localhost:5173
